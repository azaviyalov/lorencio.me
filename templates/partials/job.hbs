{{#each this}}
  <article class="job{{#if @first}} job--primary{{/if}}" role="listitem">
    <div class="job__content">
      <header class="job__header">
        <h3 class="job__title">{{link company.url company.name}}{{#if title}} — {{title}}{{/if}}</h3>
        <time class="job__period">{{period}}</time>
      </header>
      {{#if company.desc}}
        <p class="job__description">{{company.desc}}</p>
      {{/if}}
      {{#if bullets}}
        <ul class="job__bullets">
          {{#each bullets}}
            <li>{{this}}</li>
          {{/each}}
        </ul>
      {{/if}}
    </div>
  </article>
{{/each}}
